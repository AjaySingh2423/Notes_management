<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Login Page</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    padding:20px;
    background:linear-gradient(-45deg,#667eea,#764ba2,#6dd5ed,#2193b0);
    background-size:400% 400%;
    animation:gradient 10s ease infinite;
}

@keyframes gradient{
    0%{
        background-position:0% 50%;
    }
    50%{
        background-position:100% 50%;
    }
    100%{
        background-position:0% 50%;
    }
}

.card{
    width:100%;
    max-width:400px;
    background:white;
    padding:35px;
    border-radius:15px;
    box-shadow:0 10px 30px rgba(0,0,0,0.25);
}

.card h2{
    text-align:center;
    margin-bottom:25px;
    color:#333;
}

.form-group{
    margin-bottom:15px;
}

.form-group input{
    width:100%;
    padding:12px;
    border:1px solid #ccc;
    border-radius:8px;
    font-size:16px;
}

.form-group input:focus{
    outline:none;
    border-color:#667eea;
}

button{
    width:100%;
    padding:12px;
    border:none;
    border-radius:8px;
    background:#667eea;
    color:white;
    font-size:16px;
    cursor:pointer;
    transition:0.3s;
}

button:hover{
    background:#764ba2;
    transform:translateY(-2px);
}

.register-link{
    text-align:center;
    margin-top:15px;
    font-size:14px;
}

.register-link a{
    color:#667eea;
    text-decoration:none;
    font-weight:bold;
}

.register-link a:hover{
    text-decoration:underline;
}

/* Mobile */
@media(max-width:480px){
    .card{
        padding:25px;
    }

    .card h2{
        font-size:24px;
    }

    .form-group input,
    button{
        font-size:15px;
    }
}
</style>
</head>

<body>

<div class="card">

    <h2>Login Page</h2>

    <form action="/login1" method="POST">

        <div class="form-group">
            <input
                type="email"
                name="email"
                placeholder="Enter Email"
                required
            >
        </div>

        <div class="form-group">
            <input
                type="passward"
                name="passward"
                placeholder="Enter Passward"
                required
            >
        </div>

        <button type="submit">Login</button>

        <div class="register-link">
            Don't have an account?
            <a href="/form">Register Here</a>
        </div>

    </form>

</div>

</body>
</html>