<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Add User</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:linear-gradient(-45deg,#667eea,#764ba2,#6dd5ed,#2193b0);
    background-size:400% 400%;
    animation:bg 8s ease infinite;
}

@keyframes bg{
    0%{background-position:0% 50%;}
    50%{background-position:100% 50%;}
    100%{background-position:0% 50%;}
}

.card{
    width:420px;
    background:white;
    padding:35px;
    border-radius:15px;
    box-shadow:0 10px 30px rgba(0,0,0,0.25);
}

.card h2{
    text-align:center;
    margin-bottom:25px;
    color:#333;
}

.card input{
    width:100%;
    padding:12px;
    margin-bottom:15px;
    border:1px solid #ccc;
    border-radius:8px;
    font-size:16px;
}

.card input:focus{
    outline:none;
    border-color:#667eea;
}

.card button{
    width:100%;
    padding:12px;
    border:none;
    border-radius:8px;
    background:#667eea;
    color:white;
    font-size:16px;
    cursor:pointer;
    transition:0.3s;
}

.card button:hover{
    background:#764ba2;
    transform:translateY(-2px);
}


@media (max-width: 480px){

    body{
        padding:15px;
    }

    .card{
        width:100%;
        padding:25px 20px;
        border-radius:12px;
    }

    .card h2{
        font-size:24px;
        margin-bottom:20px;
    }

    .card input,
    .card button{
        font-size:15px;
        padding:12px;
    }
}
</style>

</head>
<body>

<div class="card">
    <h2>Add User</h2>

    <form action="/addUser" method="POST" onsubmit="return validateForm()">
        <input type="text" name="name" placeholder="Enter Name" required>

        <input type="email" name="email" placeholder="Enter Email" required>

        <input type="password" name="passward" placeholder="Enter Password" required id="passward">
        <input type="password" name="con_passward" placeholder="Confirm Password" required id="con_passward">

        <button type="submit">Add User</button>
    </form>
</div>

</body>
<script>
function validateForm() {

    let password = document.getElementById("passward").value;
    let confirmPassword = document.getElementById("con_passward").value;

    if (password !== confirmPassword) {
        alert("Passwords do not match!");
        return false;
    }

    return true;
}
</script>
</html>