<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact</title>
     <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/layout.css">
    <style>
    /* 🔹 Title Input */
.title-input {
  display: block;
  margin: 20px auto;
  width: 60%;
  padding: 10px;

  border: 1px solid #ccc;
  border-radius: 8px;
  outline: none;

  text-align: center;
}

/* 🔹 Save Button */
.save-btn {
  display: block;
  margin: 20px auto;
  padding: 10px 20px;

  border: none;
  border-radius: 8px;

  background-color: #28a745;
  color: white;
  cursor: pointer;
}

/* 📱 Mobile */
@media (max-width: 600px) {
  .title-input {
    width: 80%;
    font-size: 14px;
  }

  .save-btn {
    width: 50%;
    font-size: 14px;
  }
}

/* 💻 Laptop */
@media (min-width: 769px) {
  .title-input {
    width: 40%;
    font-size: 16px;
  }

  .save-btn {
    width: 150px;
    font-size: 16px;
  }
}
.ql-undo::before { content: "↺"; }
.ql-redo::before { content: "↻"; }
.ql-container {
  background-color: white;
}

.ql-editor {
  background-color: white;
}                            
</style>
<link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" rel="stylesheet">
</head>
<body>
 <div id="top-bar">
     <p id="p1"><%= user.name %></p>
